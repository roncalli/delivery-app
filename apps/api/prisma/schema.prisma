// Modelo de dados completo da plataforma.
// Os enums espelham packages/shared/src/index.ts — mantenha os dois em sincronia.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================= USUÁRIOS =============================

enum UserRole {
  CUSTOMER
  STORE_OWNER
  COURIER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  role         UserRole @default(CUSTOMER)
  name         String
  phone        String   @unique // formato E.164: +5599999999999
  email        String?  @unique
  passwordHash String? // login por senha (lojista/admin); cliente usa OTP
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses Address[]
  stores    Store[]
  courier   Courier?
  orders    Order[]
  reviews   Review[]

  @@map("users")
}

model Address {
  id           String  @id @default(cuid())
  userId       String
  label        String? // "Casa", "Trabalho"
  street       String
  number       String
  complement   String?
  neighborhood String
  cityId       String
  lat          Float?
  lng          Float?
  isDefault    Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  city   City    @relation(fields: [cityId], references: [id])
  orders Order[]

  @@map("addresses")
}

// ============================= CIDADES E LOJAS =============================

model City {
  id     String  @id @default(cuid())
  name   String
  state  String // UF, ex. "MG"
  active Boolean @default(true)

  stores    Store[]
  addresses Address[]

  @@unique([name, state])
  @@map("cities")
}

enum StoreStatus {
  PENDING
  ACTIVE
  PAUSED
  SUSPENDED
}

enum DeliveryMode {
  OWN
  PLATFORM
  HYBRID
}

model Store {
  id             String       @id @default(cuid())
  cityId         String
  ownerId        String
  name           String
  slug           String       @unique // URL pública: /loja/pizzaria-do-ze
  category       String // "Pizza", "Lanches", "Mercado", "Farmácia"...
  document       String // CNPJ ou CPF
  description    String?
  logoUrl        String?
  coverUrl       String?
  status         StoreStatus  @default(PENDING)
  deliveryMode   DeliveryMode @default(OWN)
  commissionPct  Decimal      @default(10) @db.Decimal(5, 2) // % da plataforma
  minOrderValue  Decimal      @default(0) @db.Decimal(10, 2)
  avgPrepMinutes Int          @default(30)
  // Horários por dia da semana: [{ day: 0-6, open: "18:00", close: "23:30" }]
  openingHours   Json         @default("[]")
  // Agregado de avaliações — atualizado na criação de cada review
  ratingAvg      Float?
  ratingCount    Int          @default(0)
  lat            Float?
  lng            Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  city           City           @relation(fields: [cityId], references: [id])
  owner          User           @relation(fields: [ownerId], references: [id])
  deliveryZones  DeliveryZone[]
  menuCategories MenuCategory[]
  products       Product[]
  orders         Order[]
  wallet         Wallet?
  coupons        Coupon[]

  @@index([cityId, status])
  @@map("stores")
}

enum ZoneType {
  RADIUS
  NEIGHBORHOOD
}

model DeliveryZone {
  id           String   @id @default(cuid())
  storeId      String
  type         ZoneType
  neighborhood String? // quando type = NEIGHBORHOOD
  radiusKm     Float? // quando type = RADIUS
  fee          Decimal  @db.Decimal(10, 2)
  etaMinutes   Int      @default(40)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("delivery_zones")
}

// ============================= CARDÁPIO =============================

model MenuCategory {
  id        String  @id @default(cuid())
  storeId   String
  name      String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("menu_categories")
}

model Product {
  id          String  @id @default(cuid())
  storeId     String
  categoryId  String
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  imageUrl    String?
  available   Boolean @default(true)
  sortOrder   Int     @default(0)

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category     MenuCategory  @relation(fields: [categoryId], references: [id])
  optionGroups OptionGroup[]
  orderItems   OrderItem[]

  @@index([storeId, available])
  @@map("products")
}

model OptionGroup {
  id        String @id @default(cuid())
  productId String
  name      String // "Escolha o molho", "Adicionais"
  minSelect Int    @default(0) // 0 = opcional
  maxSelect Int    @default(1)
  sortOrder Int    @default(0)

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  options Option[]

  @@map("option_groups")
}

model Option {
  id         String  @id @default(cuid())
  groupId    String
  name       String
  extraPrice Decimal @default(0) @db.Decimal(10, 2)
  available  Boolean @default(true)

  group            OptionGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItemOptions OrderItemOption[]

  @@map("options")
}

// ============================= PEDIDOS =============================

enum OrderStatus {
  CREATED
  ACCEPTED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELED
}

enum PaymentMethod {
  PIX
  CARD_ONLINE
  ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  REFUNDED
  FAILED
}

model Order {
  id            String        @id @default(cuid())
  number        Int           @unique @default(autoincrement()) // número curto p/ comanda
  customerId    String
  storeId       String
  addressId     String
  couponId      String?
  status        OrderStatus   @default(CREATED)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  // ON_DELIVERY: "cash" precisa de troco para changeFor; "card" maquininha
  changeFor     Decimal?      @db.Decimal(10, 2)
  subtotal      Decimal       @db.Decimal(10, 2)
  deliveryFee   Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  customerNote  String?
  cancelReason  String?
  canceledBy    UserRole?
  // ID da cobrança no gateway de pagamento (Pix/cartão)
  gatewayChargeId String?

  createdAt       DateTime  @default(now())
  acceptedAt      DateTime?
  readyAt         DateTime?
  outForDeliveryAt DateTime?
  deliveredAt     DateTime?
  canceledAt      DateTime?

  customer     User        @relation(fields: [customerId], references: [id])
  store        Store       @relation(fields: [storeId], references: [id])
  address      Address     @relation(fields: [addressId], references: [id])
  coupon       Coupon?     @relation(fields: [couponId], references: [id])
  items        OrderItem[]
  delivery     Delivery?
  review       Review?
  transactions Transaction[]

  @@index([storeId, status])
  @@index([customerId, createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  // Snapshot no momento do pedido (preço/nome podem mudar depois)
  name      String
  unitPrice Decimal @db.Decimal(10, 2)
  quantity  Int
  note      String?

  order   Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product           @relation(fields: [productId], references: [id])
  options OrderItemOption[]

  @@map("order_items")
}

model OrderItemOption {
  id          String  @id @default(cuid())
  orderItemId String
  optionId    String
  name        String // snapshot
  extraPrice  Decimal @db.Decimal(10, 2)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  option    Option    @relation(fields: [optionId], references: [id])

  @@map("order_item_options")
}

// ============================= LOGÍSTICA (Fase 2) =============================

enum CourierStatus {
  PENDING
  ACTIVE
  BLOCKED
}

model Courier {
  id            String        @id @default(cuid())
  userId        String        @unique
  vehicle       String // "moto", "bike", "carro"
  documentUrl   String? // CNH/documentos enviados
  status        CourierStatus @default(PENDING)
  online        Boolean       @default(false)
  lastLat       Float?
  lastLng       Float?
  lastSeenAt    DateTime?

  user       User       @relation(fields: [userId], references: [id])
  deliveries Delivery[]
  wallet     Wallet?

  @@map("couriers")
}

enum DeliveryStatus {
  SEARCHING
  ASSIGNED
  PICKED_UP
  DELIVERED
  FAILED
}

model Delivery {
  id         String         @id @default(cuid())
  orderId    String         @unique
  courierId  String?
  status     DeliveryStatus @default(SEARCHING)
  fee        Decimal        @db.Decimal(10, 2) // valor da corrida p/ entregador
  assignedAt DateTime?
  pickedUpAt DateTime?
  deliveredAt DateTime?

  order   Order    @relation(fields: [orderId], references: [id])
  courier Courier? @relation(fields: [courierId], references: [id])

  @@map("deliveries")
}

// ============================= FINANCEIRO =============================

enum WalletOwnerType {
  STORE
  COURIER
}

model Wallet {
  id        String          @id @default(cuid())
  ownerType WalletOwnerType
  storeId   String?         @unique
  courierId String?         @unique
  balance   Decimal         @default(0) @db.Decimal(12, 2)
  pixKey    String?

  store        Store?        @relation(fields: [storeId], references: [id])
  courier      Courier?      @relation(fields: [courierId], references: [id])
  transactions Transaction[]
  payouts      Payout[]

  @@map("wallets")
}

enum TransactionType {
  SALE
  COMMISSION
  DELIVERY_FEE
  PAYOUT
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  SETTLED
  CANCELED
}

model Transaction {
  id        String            @id @default(cuid())
  walletId  String
  orderId   String?
  type      TransactionType
  status    TransactionStatus @default(PENDING)
  amount    Decimal           @db.Decimal(12, 2) // positivo = crédito, negativo = débito
  note      String?
  createdAt DateTime          @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
  order  Order? @relation(fields: [orderId], references: [id])

  @@index([walletId, createdAt])
  @@map("transactions")
}

model Payout {
  id          String    @id @default(cuid())
  walletId    String
  amount      Decimal   @db.Decimal(12, 2)
  pixKey      String
  status      String    @default("pending") // pending | processing | done | failed
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@map("payouts")
}

// ============================= CUPONS E AVALIAÇÕES =============================

enum CouponScope {
  PLATFORM
  STORE
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_DELIVERY
}

model Coupon {
  id            String      @id @default(cuid())
  scope         CouponScope
  storeId       String? // quando scope = STORE
  code          String      @unique
  type          CouponType
  value         Decimal     @db.Decimal(10, 2) // % ou R$ conforme type
  minOrderValue Decimal     @default(0) @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int         @default(0)
  expiresAt     DateTime?
  active        Boolean     @default(true)

  store  Store?  @relation(fields: [storeId], references: [id])
  orders Order[]

  @@map("coupons")
}

model Review {
  id            String   @id @default(cuid())
  orderId       String   @unique
  customerId    String
  storeRating   Int // 1–5
  courierRating Int? // 1–5
  comment       String?
  createdAt     DateTime @default(now())

  order    Order @relation(fields: [orderId], references: [id])
  customer User  @relation(fields: [customerId], references: [id])

  @@map("reviews")
}
