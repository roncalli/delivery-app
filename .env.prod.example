# PRODUÇÃO — copie para .env na VPS e preencha TUDO.
# Nunca commite o .env preenchido.

# --- Domínios (crie os registros DNS A apontando para o IP da VPS) ---
WEB_DOMAIN=app.seudominio.com.br
API_DOMAIN=api.seudominio.com.br

# --- Banco (o compose monta a DATABASE_URL sozinho) ---
POSTGRES_PASSWORD=troque-por-uma-senha-longa-e-aleatoria

# --- API ---
API_PORT=3001
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio-diferente-do-dev
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Pedidos ---
ORDER_ACCEPT_WARN_MS=300000
ORDER_ACCEPT_CANCEL_MS=600000
PIX_EXPIRE_MS=900000

# --- Pagamentos (produção = asaas com conta real/sandbox) ---
PAYMENT_GATEWAY=asaas
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=troque-por-um-token-aleatorio
PAYMENT_WEBHOOK_TOKEN=

# --- OTP (produção: WhatsApp/SMS — implementar provider no OtpService) ---
OTP_PROVIDER=mock

# --- Observabilidade ---
SENTRY_DSN=
