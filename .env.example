# Copie para .env e ajuste os valores. NUNCA commite o .env.

# --- Banco de dados (docker-compose) ---
DATABASE_URL="postgresql://delivery:delivery_dev@localhost:5432/delivery?schema=public"

# --- Redis (docker-compose) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=3001
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_WS_URL="http://localhost:3001"

# --- Pagamentos (Etapa 7 — sandbox do gateway escolhido) ---
PAYMENT_GATEWAY="asaas"
ASAAS_API_KEY=""
ASAAS_WEBHOOK_TOKEN=""

# --- Armazenamento de imagens (Etapa 3 — R2/S3) ---
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Mensageria / OTP (Etapa 2 — mock em dev) ---
OTP_PROVIDER="mock"
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# --- Observabilidade ---
SENTRY_DSN=""
