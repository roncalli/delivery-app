# Copie para .env e ajuste os valores. NUNCA commite o .env.

# --- Banco de dados (docker-compose) ---
DATABASE_URL="postgresql://delivery:delivery_dev@localhost:5432/delivery?schema=public"

# --- Redis (docker-compose) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=3001
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Pedidos: timeouts de aceite do lojista (ms) ---
# aviso ao admin após 5 min sem aceite; cancelamento automático após 10 min
ORDER_ACCEPT_WARN_MS=300000
ORDER_ACCEPT_CANCEL_MS=600000

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_WS_URL="http://localhost:3001"

# --- Pagamentos (Etapa 7) ---
# mock: dev/testes (botão "Simular pagamento") | asaas: produção/sandbox
PAYMENT_GATEWAY="mock"
# token exigido no header x-webhook-token do webhook mock
PAYMENT_WEBHOOK_TOKEN="dev-webhook-token"
# prazo para pagar o Pix antes do pedido ser cancelado (ms)
PIX_EXPIRE_MS=900000
# Asaas (quando PAYMENT_GATEWAY=asaas)
ASAAS_BASE_URL="https://api-sandbox.asaas.com/v3"
ASAAS_API_KEY=""
ASAAS_WEBHOOK_TOKEN=""

# --- Armazenamento de imagens (Etapa 3 — R2/S3) ---
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Mensageria / OTP (Etapa 2 — mock em dev) ---
OTP_PROVIDER="mock"
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# --- Observabilidade ---
SENTRY_DSN=""
